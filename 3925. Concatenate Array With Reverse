class Solution{
    public int[] concatWithReverse(int[] nums){
        int n=nums.length;
        int ans[]=new int[n*2];
        for(int i=0;i<n;i++){
            ans[i]=nums[i];
        }
        int ind=n-1;
        for(int i=n;i<n*2;i++){
            ans[i]=nums[ind--];
        }
        return ans;
    }
}
