class Solution{
    public int minLights(int[] lights){
        int n=lights.length;
        int freq[]=new int[n+1];
        for(int i=0;i<n;i++){
            if(lights[i]>0){
                freq[Math.max(0,i-lights[i])]++;
                freq[Math.min(n-1,i+lights[i])+1]--;
            }
        }
        int cur=0;
        int ans=0;
        int sum=0;
        for(int i=0;i<n;i++){
            sum+=freq[i];
            if(sum==0){
                cur++;
                if(cur==3){
                    ans++;
                    cur=0;
                }
            }else{
                if(cur>0) ans++;
                cur=0;
            }
        }
        return ans+(cur>0?1:0);
    }
}
