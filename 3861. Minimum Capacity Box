class Solution {
    public int minimumIndex(int[] capacity, int itemSize) {
        int min_val=Integer.MAX_VALUE;
        int min_ind=-1;
        for(int i=0;i<capacity.length;i++){
            if(capacity[i]>=itemSize && capacity[i]<min_val){
                min_val=capacity[i];
                min_ind=i;
            }
        }
        return min_ind;
    }
}
