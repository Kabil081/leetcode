class Solution {
    public int numberOfSubmatrices(char[][] grid) {
        int m=grid.length;
        int n=grid[0].length;
        int matrix[][]=new int[m][n];
        int x_count[][]=new int[m][n];
        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                if(grid[i][j]=='X') matrix[i][j]=1;
                else if(grid[i][j]=='Y') matrix[i][j]=-1;
            }
        }
        int count=0;
        x_count[0][0]=matrix[0][0]==1?1:0;
        for(int i=1;i<n;i++){
            int val=0;
            if(matrix[0][i]==1) val=1;
            matrix[0][i]=matrix[0][i]+matrix[0][i-1];
            x_count[0][i]=val+x_count[0][i-1];
            if(matrix[0][i]==0 && x_count[0][i]>0) count++;
        }
        for(int i=1;i<m;i++){
            int val=0;
            if(matrix[i][0]==1) val=1;
            matrix[i][0]=matrix[i][0]+matrix[i-1][0];
            x_count[i][0]=x_count[i-1][0]+val;
            if(x_count[i][0]>0 && matrix[i][0]==0){
                count++;
            }
        }
        for(int i=1;i<m;i++){
            for(int j=1;j<n;j++){
                int val=0;
                if(matrix[i][j]==1) val=1;
                matrix[i][j]=matrix[i][j-1]+(matrix[i-1][j]-matrix[i-1][j-1])+matrix[i][j];
                x_count[i][j]=x_count[i][j-1]+(x_count[i-1][j]-x_count[i-1][j-1])+val;
                if(x_count[i][j]>0 && matrix[i][j]==0){
                    count++;
                }
            }
        }
        return count;
    }
}
