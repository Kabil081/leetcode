class Solution{
    public int rotatedDigits(int n){
        int count=0;
        for(int i=2;i<=n;i++){
            if(valid(i)) count++;
        }
        return count;
    }
    public boolean valid(int num){
        boolean has=false;
        while(num>0){
            int digit=num%10;
            if(digit==3 || digit==4 || digit==7) return false;
            if(digit==2 || digit==5 || digit==6 || digit==9) has=true;
            num/=10;
        }
        return has;
    }
}
