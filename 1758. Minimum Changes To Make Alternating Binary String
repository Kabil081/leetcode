class Solution{
    public int minOperations(String s){
        return Math.min(helper(s,0),helper(s,1));
    }
    public int helper(String s,int num){
        int count=0;
        for(int i=0;i<s.length();i++){
            if(s.charAt(i)-'0'==num) count++;
            num=num==0?1:0;
        }
        return count;
    }
}
