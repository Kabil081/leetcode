class Solution{
    public int[] findDegrees(int[][] matrix) {
        int m=matrix.length;
        int n=matrix[0].length;
        int res[]=new int[m];
        for(int i=0;i<m;i++){
            int ans=0;
            for(int j=0;j<n;j++){
                if(i==j) continue;
                if(matrix[i][j]==1) ans++;
            }
            res[i]=ans;
        }
        return res;
    }
}
