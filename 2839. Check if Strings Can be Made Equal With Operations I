class Solution{
    public boolean canBeEqual(String s1, String s2){
        for(int i=0;i<2;i++){
            if(s1.charAt(i)-'a'!=s2.charAt(i)-'a' && s1.charAt(i)-'a'!=s2.charAt(i+2)-'a') return false;
            if(s2.charAt(i)-'a'!=s1.charAt(i)-'a' && s2.charAt(i)-'a'!=s1.charAt(i+2)-'a') return false;
        }
        for(int i=2;i<4;i++){
            if(s1.charAt(i)-'a'!=s2.charAt(i)-'a' && s1.charAt(i)-'a'!=s2.charAt(i-2)-'a') return false;
            if(s2.charAt(i)-'a'!=s1.charAt(i)-'a' && s2.charAt(i)-'a'!=s1.charAt(i-2)-'a') return false;
        }
        return true;
    }
}
