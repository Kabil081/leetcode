class Solution{
    public int minSwaps(int[][] grid){
        int m=grid.length;
        int n=grid[0].length;
        int swaps=0;
        int zeros[]=new int[n];
        for(int i=0;i<m;i++){
            int count=0;
            for(int j=n-1;j>=0 && grid[i][j]==0;j--){
                count++;
            }
            zeros[i]=count;
        }
        for(int i=0;i<n;i++){
            int needed=n-i-1;
            int j=i;
            while(j<n && needed>zeros[j]){
                j++;
            }
            if(j==n) return -1;
            while(j>i){
                int temp=zeros[j];
                zeros[j]=zeros[j-1];
                zeros[j-1]=temp;
                swaps++;
                j--;
            }
        }
        return swaps;
    }
}
