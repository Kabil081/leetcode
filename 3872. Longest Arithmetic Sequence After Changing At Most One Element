class Solution{
    public int longestArithmetic(int[] nums){
        int n=nums.length;
        int m=n-1;
        int left[]=new int[m];
        int right[]=new int[m];
        int gaps[]=new int[m];
        for(int i=1;i<n;i++){
            gaps[i-1]=nums[i]-nums[i-1];
        }
        left[0]=1;
        right[m-1]=1;
        for(int i=1;i<m;i++){
            left[i]=(gaps[i]==gaps[i-1])?left[i-1]+1:1;
        }
        for(int i=m-2;i>=0;i--){
            right[i]=(gaps[i]==gaps[i+1])?right[i+1]+1:1;
        }
        int ans=3;
        for(int i=0;i<m;i++){
            if(left[i]==m){
                ans=Math.max(ans,m+1);
            }else{
                ans=Math.max(ans,left[i]+2);
            }
        }
        for(int i=1;i<m;i++){
            int sum=gaps[i]+gaps[i-1];
            if(i>=2 && sum==2*gaps[i-2]){
                ans=Math.max(ans,left[i-2]+3);
            }
            if(i<=m-2 && sum==2*gaps[i+1]){
                ans=Math.max(ans,right[i+1]+3);
            }
            if(i>=2 && i<=m-2 && sum==2*gaps[i-2] && sum==2*gaps[i+1]){
                ans=Math.max(ans,left[i-2]+right[i+1]+3);
            }
        }
        return ans;
    }
}
