class Solution {
    public int passwordStrength(String password) {
        int freq[]=new int[128];
        int count=0;
        for(char ch:password.toCharArray()){
            if(freq[ch-'!']==0){
                if(ch>='a' && ch<='z'){
                    count++;
                }else if(ch>='A' && ch<='Z'){
                    count+=2;
                }else if(ch>='0' && ch<='9'){
                    count+=3;
                }else{
                    count+=5;
                }
                freq[ch-'!']++;
            }
        }
        return count;
    }
}
