class Solution{
    public int minOperations(String s){
        if(is_sorted(s)) return 0;
        int min_val=27;
        int max_val=-1;
        int min_ind=-1;
        int max_ind=-1;
        int n=s.length();
        for(int i=0;i<s.length();i++){
            int ind=s.charAt(i)-'a';
            if(ind<min_val){ 
                min_val=ind;
                min_ind=i;
            }
            if(ind>=max_val){ 
                max_val=ind;
                max_ind=i;
            }
        }
        if(s.length()==2 && min_ind==n-1) return -1;
        else if(max_ind==0 && min_ind==n-1) return 3;
        else if(max_ind==n-1 || min_ind==0) return 1;
        return 2;
    }
    public boolean is_sorted(String s){
        int ind=s.charAt(0)-'a';
        for(int i=1;i<s.length();i++){
            if(ind>s.charAt(i)-'a') return false;
            ind=s.charAt(i)-'a';
        }
        return true;
    }
}
