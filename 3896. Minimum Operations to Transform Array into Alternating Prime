class Solution{
    public int minOperations(int[] nums){
        boolean isPrime[]=seive();
        int ans=0;
        for(int i=0;i<nums.length;i++){
            int num=nums[i];
            if(i%2==0){
                while(!isPrime[num]){
                    num++;
                    ans++;
                }
            }else{
                while(isPrime[num]){
                    num++;
                    ans++;
                }
            }
        }
        return ans;
    }
    public boolean[] seive(){
        boolean isPrime[]=new boolean[100004];
        Arrays.fill(isPrime,true);
        isPrime[1]=false;
        for(int i=2;i*i<=100003;i++){
            if(isPrime[i]){ 
                for(int j=i+i;j<=100003;j+=i){
                    isPrime[j]=false;
                }
            }
        }
        return isPrime;
    }
}
