class Solution{
    class Node{
        int node;
        double prob;
        Node(int node,double prob){
            this.node=node;
            this.prob=prob;
        }
    }
    public double maxProbability(int n, int[][] edges, double[] succProb, int start_node, int end_node){
        PriorityQueue<Node> pq =new PriorityQueue<>((a, b) -> Double.compare(b.prob, a.prob));
        double dist[]=new double[n];
        List<List<Node>> list=new ArrayList<>();
        for(int i=0;i<n;i++) list.add(i,new ArrayList<>());
        int ind=0;
        for(int edge[]:edges){
            list.get(edge[0]).add(new Node(edge[1],succProb[ind]));
            list.get(edge[1]).add(new Node(edge[0],succProb[ind]));
            ind++;
        }
        boolean visited[]=new boolean[n];
        for(Node cur:list.get(start_node)){
            int node=cur.node;
            double prob=cur.prob;
            dist[node]=prob;
            pq.add(cur);
        }
        visited[start_node]=true;
        while(!pq.isEmpty()){
            Node cur=pq.poll();
            int node=cur.node;
            double prob=cur.prob;
            if(node==end_node){
                continue;
            }
            visited[node]=true;
            for(Node t:list.get(node)){
                dist[t.node]=Math.max(dist[t.node],prob*t.prob);
                if(visited[t.node]) continue;
                pq.add(new Node(t.node,prob*t.prob));
            }
        }
        return dist[end_node];
    }
}
