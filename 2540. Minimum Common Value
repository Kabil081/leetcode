class Solution{
    public int getCommon(int[] nums1, int[] nums2){
        int ind1=0,ind2=0;
        while(ind1<nums1.length && ind2<nums2.length){
            if(nums1[ind1]==nums2[ind2]) return nums1[ind1];
            else if(nums1[ind1]<=nums2[ind2]){
                ind1++;
            }else{
                ind2++;
            }
        }
        return -1;
    }
}
